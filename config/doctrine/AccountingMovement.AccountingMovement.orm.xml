<?xml version="1.0" encoding="utf-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
  <entity repository-class="xVer\MiCartera\Infrastructure\AccountingMovement\AccountingMovementRepositoryDoctrine" name="xVer\MiCartera\Domain\AccountingMovement\AccountingMovement" table="accountingMovement" change-tracking-policy="DEFERRED_EXPLICIT">
    <id name="buyTransaction" association-key="true" unique="true"/>
    <id name="sellTransaction" association-key="true" unique="true"/>
    <many-to-one field="buyTransaction" target-entity="xVer\MiCartera\Domain\Transaction\Transaction" fetch="LAZY">
      <join-columns>
        <join-column referenced-column-name="id" on-delete="CASCADE"/>
      </join-columns>
    </many-to-one>
    <many-to-one field="sellTransaction" target-entity="xVer\MiCartera\Domain\Transaction\Transaction" fetch="LAZY">
      <join-columns>
        <join-column referenced-column-name="id" on-delete="CASCADE"/>
      </join-columns>
    </many-to-one>
    <field name="amount" type="integer" column="amount" nullable="false">
      <options>
        <option name="unsigned">true</option>
      </options>
    </field>
  </entity>
</doctrine-mapping>
